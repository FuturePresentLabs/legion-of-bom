# Rust build artifacts
/target/
**/*.rs.bk
# Cargo.lock IS committed: this is a binary/app workspace (lob), not a library.

# Python virtualenv for the SKiDL stage (recreate from requirements.txt)
/.venv/
__pycache__/
*.pyc

# SKiDL working-directory artifacts (ERC reports, logs, auto-generated backup
# libraries). The runner directs these into out/; ignore any that escape to root.
*.erc
*.log
*_sklib.py
skidl.cfg

# Local pipeline outputs / scratch (generated netlists, boards, gerbers)
/out/

# Secrets — API keys/tokens. NEVER commit. Commit .env.example (unignored) instead.
.env
.env.*
!.env.example

# OS / editor
.DS_Store

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
.beads/proxieddb/
